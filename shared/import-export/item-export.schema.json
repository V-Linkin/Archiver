{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ItemExport",
  "description": "导出时 Item 的字段定义 — 复用 shared/model/item.schema.json 的字段语义",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "主键，UUID v4"
    },
    "title": {
      "type": ["string", "null"],
      "description": "标题"
    },
    "body": {
      "type": ["string", "null"],
      "description": "正文内容"
    },
    "originalURL": {
      "type": "string",
      "description": "原始链接"
    },
    "platform": {
      "type": "string",
      "description": "来源平台 rawValue",
      "enum": ["douyin", "xiaohongshu", "coolapk", "bilibili", "github", "youtube", "x", "weibo", "zhihu", "douban", "custom"]
    },
    "platformContentID": {
      "type": ["string", "null"],
      "description": "平台内容 ID"
    },
    "normalizedURL": {
      "type": "string",
      "description": "标准化 URL（去重用）"
    },
    "author": {
      "type": ["string", "null"],
      "description": "作者名"
    },
    "authorID": {
      "type": ["string", "null"],
      "description": "平台作者 ID"
    },
    "publishDate": {
      "type": ["number", "null"],
      "description": "发布时间，Unix timestamp（秒）"
    },
    "importDate": {
      "type": "number",
      "description": "导入时间，Unix timestamp（秒）"
    },
    "modifyDate": {
      "type": "number",
      "description": "修改时间，Unix timestamp（秒）"
    },
    "contentStatus": {
      "type": "string",
      "description": "内容状态 rawValue",
      "enum": ["normal", "parseFailed", "mediaIncomplete", "sourceDeleted", "trashed"]
    },
    "archiveStatus": {
      "type": "string",
      "description": "归档状态 rawValue",
      "enum": ["favorite", "inspiration", "pending", "archived"]
    },
    "mediaStatus": {
      "type": "string",
      "description": "媒体保存状态 rawValue",
      "enum": ["complete", "partial", "failed", "textOnly"]
    },
    "coverAssetID": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "封面媒体资产 ID"
    },
    "folderID": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "所属文件夹 ID"
    },
    "customPlatformID": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "自定义平台 ID"
    },
    "remark": {
      "type": ["string", "null"],
      "description": "用户备注"
    },
    "isStarred": {
      "type": "boolean",
      "description": "是否收藏"
    },
    "version": {
      "type": "integer",
      "description": "版本号"
    },
    "deletedAt": {
      "type": ["number", "null"],
      "description": "删除时间，Unix timestamp（秒）。NULL = 未删除"
    }
  },
  "required": [
    "id",
    "originalURL",
    "platform",
    "normalizedURL",
    "importDate",
    "modifyDate",
    "contentStatus",
    "archiveStatus",
    "mediaStatus",
    "isStarred",
    "version"
  ]
}
