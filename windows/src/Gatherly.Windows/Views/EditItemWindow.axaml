<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Gatherly.Windows.Views"
        xmlns:controls="clr-namespace:Gatherly.Windows.Views.Components"
        x:Class="Gatherly.Windows.Views.EditItemWindow"
        Title="编辑内容"
        Width="600" Height="600"
        MinWidth="400" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Closing="Window_Closing">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FAFAFA"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="编辑内容" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Content="取消" Click="CancelButton_Click" Padding="16,6" FontSize="13" />
                    <Button Content="保存" Click="SaveButton_Click"
                            Padding="16,6" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer>
            <StackPanel Spacing="16" Margin="24,16,24,16">
                <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="标题" FontSize="12" Foreground="#888" />
                        <TextBox x:Name="TitleBox" Watermark="输入标题" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                        <TextBlock Text="作者" FontSize="12" Foreground="#888" />
                        <TextBox x:Name="AuthorBox" Watermark="输入作者" />
                    </StackPanel>
                </Grid>
                <StackPanel Spacing="4">
                    <DockPanel>
                        <TextBlock Text="正文" FontSize="12" Foreground="#888"
                                   VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2">
                            <Button x:Name="BoldBtn" Content="B" Click="Bold_Click"
                                    Padding="6,2" FontSize="12" FontWeight="Bold"
                                    ToolTip.Tip="粗体" />
                            <Button x:Name="ItalicBtn" Content="I" Click="Italic_Click"
                                    Padding="6,2" FontSize="12" FontStyle="Italic"
                                    ToolTip.Tip="斜体" />
                            <Button x:Name="CodeBtn" Content="&lt;/&gt;" Click="Code_Click"
                                    Padding="6,2" FontSize="11"
                                    ToolTip.Tip="行内代码" />
                            <Button x:Name="LinkBtn" Content="🔗" Click="Link_Click"
                                    Padding="6,2" FontSize="12"
                                    ToolTip.Tip="链接" />
                            <Border Width="1" Height="16" Background="#E0E0E0" Margin="4,0" />
                            <Button x:Name="EditToggleBtn" Content="编辑" Click="EditToggle_Click"
                                    Padding="8,2" FontSize="12" FontWeight="SemiBold" />
                            <Button x:Name="PreviewToggleBtn" Content="预览" Click="PreviewToggle_Click"
                                    Padding="8,2" FontSize="12" />
                        </StackPanel>
                    </DockPanel>
                    <TextBox x:Name="BodyBox" Watermark="输入正文内容，支持 Markdown 格式"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="120" />
                    <Border x:Name="PreviewBorder" IsVisible="False"
                            Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="6" Padding="12" MinHeight="120">
                        <ScrollViewer>
                            <StackPanel>
                                <controls:MarkdownTextBlock x:Name="BodyPreviewRenderer" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="备注" FontSize="12" Foreground="#888" />
                    <TextBox x:Name="RemarkBox" Watermark="输入备注"
                             AcceptsReturn="True" MinHeight="60" />
                </StackPanel>

                <!-- Images -->
                <StackPanel Spacing="4">
                    <DockPanel>
                        <TextBlock Text="图片" FontSize="12" Foreground="#888"
                                   VerticalAlignment="Center" />
                        <Button Content="+ 添加图片" Click="AddImage_Click"
                                DockPanel.Dock="Right" Padding="10,4" FontSize="12"
                                HorizontalAlignment="Right" />
                    </DockPanel>
                    <WrapPanel x:Name="ImageWrapPanel" />
                    <TextBlock x:Name="NoImagesText" Text="暂无图片" FontSize="11"
                               Foreground="#aaa" IsVisible="True" />
                </StackPanel>

                <!-- Videos -->
                <StackPanel Spacing="4">
                    <DockPanel>
                        <TextBlock Text="视频" FontSize="12" Foreground="#888"
                                   VerticalAlignment="Center" />
                        <Button Content="+ 添加视频" Click="AddVideo_Click"
                                DockPanel.Dock="Right" Padding="10,4" FontSize="12"
                                HorizontalAlignment="Right" />
                    </DockPanel>
                    <StackPanel x:Name="VideoStackPanel" />
                    <TextBlock x:Name="NoVideosText" Text="暂无视频" FontSize="11"
                               Foreground="#aaa" IsVisible="True" />
                </StackPanel>

                <TextBlock x:Name="ErrorTextBlock" Text="" Foreground="#D32F2F"
                           FontSize="12" IsVisible="False" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
