<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:m="using:Gatherly.Windows.Models"
             xmlns:conv="using:Gatherly.Windows.Views.Converters"
             x:Class="Gatherly.Windows.Views.ContentListView"
             x:DataType="vm:ContentListViewModel">

    <DockPanel>
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8" Spacing="4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Folder mode: back + folder name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding IsInFolder}">
                    <Button Content="← 返回" Click="BackButton_Click"
                            Padding="10,4" FontSize="12" />
                    <TextBlock Text="{Binding FolderTitle}" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <!-- Platform mode: title + new folder button -->
                <TextBlock Grid.Column="0" Text="内容列表"
                           FontSize="18" FontWeight="Bold"
                           IsVisible="{Binding !IsInFolder}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                            IsVisible="{Binding !IsInFolder}">
                    <Button Content="+ 新建文件夹" Click="NewFolder_Click"
                            Padding="10,4" FontSize="12" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="正在加载..."
                   IsVisible="{Binding IsBusy}"
                   Margin="16,4" />

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="Red" Margin="16,4" />

        <!-- Folder bar — only show on platform level, not inside folder -->
        <ScrollViewer DockPanel.Dock="Top"
                      IsVisible="{Binding !IsInFolder}"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Margin="12,0,12,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ItemsControl ItemsSource="{Binding Folders}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="m:Folder">
                            <Border Padding="12,6" CornerRadius="6"
                                    Background="#E8F0FE" BorderBrush="#C5D8F0" BorderThickness="1"
                                    Cursor="Hand" Tag="{Binding}"
                                    PointerPressed="FolderTag_PointerPressed">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="重命名" Click="FolderRename_Click"
                                                  Tag="{Binding}" />
                                        <MenuItem Header="删除" Click="FolderDelete_Click"
                                                  Tag="{Binding}" />
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#1A73E8" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top"
                   Text="暂无内容"
                   IsVisible="{Binding !HasItems}"
                   Foreground="Gray" FontSize="14" Margin="16,8" />

        <!-- Card grid -->
        <ListBox x:Name="ItemListBox"
                 ItemsSource="{Binding Items}"
                 IsVisible="{Binding HasItems}"
                 Background="Transparent" BorderThickness="0"
                 Padding="0" Margin="12,0">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Item">
                    <Border Width="200" Margin="0,0,12,12" CornerRadius="8"
                            ClipToBounds="True" Background="#F8F8F8"
                            BorderBrush="#E0E0E0" BorderThickness="1"
                            PointerPressed="CardBorder_PointerPressed">
                        <Border.ContextFlyout>
                            <MenuFlyout>
                                <MenuItem x:Name="MoveToPlatformMenu" Header="移动到平台" Click="MoveToPlatform_Click"
                                          Tag="{Binding}" />
                                <MenuItem Header="移动到文件夹" Click="MoveToFolder_Click"
                                          Tag="{Binding}" />
                                <MenuItem x:Name="DeleteItemMenu" Header="删除" Click="DeleteItem_Click"
                                          Tag="{Binding}" />
                            </MenuFlyout>
                        </Border.ContextFlyout>
                        <StackPanel>
                            <!-- 封面图 -->
                            <Border Height="140" Background="#F0F0F0">
                                <Image Source="{Binding FirstImagePath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <!-- 文字区 -->
                            <StackPanel Margin="8,6,8,8" Spacing="3">
                                <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}"
                                           FontWeight="SemiBold" FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="2" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DisplayPlatform}"
                                               FontSize="11" Foreground="#666" />
                                    <TextBlock Text="{Binding Author, FallbackValue='未知作者'}"
                                               FontSize="11" Foreground="#999"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
