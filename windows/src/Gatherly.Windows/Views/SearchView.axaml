<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:m="using:Gatherly.Windows.Models"
             xmlns:conv="using:Gatherly.Windows.Views.Converters"
             x:DataType="vm:SearchViewModel"
             x:Class="Gatherly.Windows.Views.SearchView">

    <DockPanel>
        <!-- Top area: title + search bar + status -->
        <TextBlock DockPanel.Dock="Top" Text="搜索"
                   FontSize="18" FontWeight="Bold" Margin="16,16,16,8" />

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Margin="16,0,16,8" Spacing="8">
            <TextBox Text="{Binding Query}" Watermark="输入关键词..."
                     Width="300" KeyDown="SearchTextBox_KeyDown" />
            <Button Content="搜索" Classes="PrimaryButton"
                    Command="{Binding SearchCommand}" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="正在搜索..."
                   IsVisible="{Binding IsBusy}"
                   Foreground="{StaticResource TextTertiary}" Margin="16,4" />

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="{StaticResource DangerRed}" Margin="16,4" />

        <TextBlock DockPanel.Dock="Top"
                   IsVisible="{Binding ShowResultCount}"
                   Foreground="{StaticResource TextTertiary}" FontSize="12" Margin="16,4">
            <TextBlock.Text>
                <MultiBinding StringFormat="共 {0} 条结果">
                    <Binding Path="ResultCount" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <!-- Content area: fills remaining space -->
        <Grid>
            <!-- Card grid -->
            <ListBox ItemsSource="{Binding Results}"
                     IsVisible="{Binding HasResults}"
                     Background="Transparent" BorderThickness="0"
                     Padding="0" Margin="12,0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="m:Item">
                        <Border Width="200" Padding="8"
                                CornerRadius="12"
                                ClipToBounds="True" Background="{StaticResource BackgroundCard}"
                                BorderBrush="{StaticResource BorderLight}" BorderThickness="1"
                                PointerPressed="SearchResultCard_PointerPressed">
                            <Border.ContextFlyout>
                                <MenuFlyout>
                                    <MenuItem Header="移动到平台" Click="SearchResultMoveToPlatform_Click"
                                              Tag="{Binding}" />
                                    <MenuItem Header="移动到文件夹" Click="SearchResultMoveToFolder_Click"
                                              Tag="{Binding}" />
                                    <MenuItem Header="删除" Click="SearchResultDelete_Click"
                                              Tag="{Binding}" />
                                </MenuFlyout>
                            </Border.ContextFlyout>
                            <StackPanel>
                                <Border Height="160" Background="{StaticResource BackgroundTertiary}"
                                        CornerRadius="8" ClipToBounds="True">
                                    <Image Source="{Binding FirstImagePath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                           Stretch="UniformToFill" />
                                </Border>
                                <StackPanel Spacing="4" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}"
                                               FontWeight="Medium" FontSize="13"
                                               TextTrimming="CharacterEllipsis" MaxLines="2" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding DisplayPlatform}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                        <TextBlock Text="{Binding Author, FallbackValue='未知作者'}"
                                                   FontSize="11" Foreground="{StaticResource TextTertiary}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state — centered in same Grid cell -->
            <StackPanel IsVisible="{Binding ShowNoResults}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="🔍" FontSize="32" HorizontalAlignment="Center" />
                <TextBlock Text="没有找到相关内容" FontSize="14"
                           Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center" />
                <TextBlock Text="尝试修改搜索关键词" FontSize="12"
                           Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
