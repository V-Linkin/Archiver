<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:m="using:Gatherly.Windows.Models"
             xmlns:conv="using:Gatherly.Windows.Views.Converters"
             x:DataType="vm:SearchViewModel"
             x:Class="Gatherly.Windows.Views.SearchView">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="搜索"
                   FontSize="18" FontWeight="Bold" Margin="16,16,16,8" />

        <!-- Search bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Margin="16,0,16,8" Spacing="8">
            <TextBox Text="{Binding Query}" Watermark="输入关键词..."
                     Width="300" KeyDown="SearchTextBox_KeyDown" />
            <Button Content="搜索" Command="{Binding SearchCommand}" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="正在搜索..."
                   IsVisible="{Binding IsBusy}"
                   Margin="16,4" />

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="Red" Margin="16,4" />

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top"
                   Text="暂无搜索结果"
                   IsVisible="{Binding !HasResults}"
                   Foreground="Gray" FontSize="14" Margin="16,8" />

        <!-- Card grid -->
        <ListBox ItemsSource="{Binding Results}"
                 SelectedItem="{Binding SelectedItem}"
                 IsVisible="{Binding HasResults}"
                 Background="Transparent" BorderThickness="0"
                 Padding="0" Margin="12,0">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Item">
                    <Border Width="200" Margin="0,0,12,12" CornerRadius="8"
                            ClipToBounds="True" Background="#F8F8F8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <!-- 封面图 -->
                            <Border Height="140" Background="#F0F0F0">
                                <Image Source="{Binding FirstImagePath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <!-- 文字区 -->
                            <StackPanel Margin="8,6,8,8" Spacing="3">
                                <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}"
                                           FontWeight="SemiBold" FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="2" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DisplayPlatform}"
                                               FontSize="11" Foreground="#666" />
                                    <TextBlock Text="{Binding Author, FallbackValue='未知作者'}"
                                               FontSize="11" Foreground="#999"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
