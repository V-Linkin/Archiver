<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:conv="using:Gatherly.Windows.Views.Converters"
             x:Class="Gatherly.Windows.Views.ItemDetailView"
             x:DataType="vm:MainWindowViewModel">

    <Panel>
        <!-- Placeholder when no item selected -->
        <StackPanel IsVisible="{Binding !HasSelectedItem}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center" />
            <TextBlock Text="选择一个内容以查看详情"
                       FontSize="16" Foreground="Gray" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Detail view when item selected -->
        <ScrollViewer IsVisible="{Binding HasSelectedItem}" Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding DisplayTitle}"
                           FontSize="20" FontWeight="Bold" TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <Border Background="#E8F0FE" CornerRadius="4" Padding="8,4">
                        <TextBlock Text="{Binding DisplayPlatform}" FontSize="13" />
                    </Border>
                    <TextBlock Text="{Binding DisplayAuthor}"
                               VerticalAlignment="Center" Foreground="Gray" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="发布时间" FontSize="12" Foreground="Gray" />
                    <TextBlock Text="{Binding DisplayPublishDate}" FontSize="13" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="导入时间" FontSize="12" Foreground="Gray" />
                    <TextBlock Text="{Binding DisplayImportDate}" FontSize="13" />
                </StackPanel>

                <Border Background="#F5F5F5" CornerRadius="6" Padding="12" Margin="0,4">
                    <TextBlock Text="{Binding DisplayBody}"
                               TextWrapping="Wrap" FontSize="14" LineHeight="22" />
                </Border>

                <!-- Image gallery -->
                <StackPanel Spacing="4"
                            IsVisible="{Binding HasImages}">
                    <TextBlock Text="图片" FontSize="12" Foreground="Gray" />
                    <ItemsControl ItemsSource="{Binding ImageAssets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MediaAssetDisplay">
                                <StackPanel Spacing="2" Margin="0,0,0,8">
                                    <Border MaxWidth="400" CornerRadius="4"
                                            ClipToBounds="True" Background="#F0F0F0">
                                        <Image Source="{Binding FullPath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                               Stretch="Uniform"
                                               MaxHeight="300" />
                                    </Border>
                                    <TextBlock Text="{Binding FileName}"
                                               FontSize="11" Foreground="Gray"
                                               IsVisible="{Binding !FileExists}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Video list (placeholder, no playback) -->
                <StackPanel Spacing="4"
                            IsVisible="{Binding HasVideos}">
                    <TextBlock Text="视频" FontSize="12" Foreground="Gray" />
                    <ItemsControl ItemsSource="{Binding VideoAssets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MediaAssetDisplay">
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                                    <TextBlock Text="🎬" FontSize="14" />
                                    <TextBlock Text="{Binding FileName}"
                                               FontSize="13" />
                                    <TextBlock Text="{Binding FileSizeDisplay}"
                                               FontSize="12" Foreground="Gray" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Remark section with edit -->
                <StackPanel Spacing="4">
                    <TextBlock Text="备注" FontSize="12" Foreground="Gray" />

                    <!-- View mode -->
                    <StackPanel IsVisible="{Binding !IsEditingRemark}" Spacing="4">
                        <TextBlock Text="{Binding DisplayRemark, FallbackValue='暂无备注'}"
                                   FontSize="13" FontStyle="Italic"
                                   TextWrapping="Wrap" />
                        <Button Content="编辑备注"
                                Command="{Binding StartEditRemarkCommand}"
                                HorizontalAlignment="Left"
                                Padding="8,4" FontSize="12" />
                    </StackPanel>

                    <!-- Edit mode -->
                    <StackPanel IsVisible="{Binding IsEditingRemark}" Spacing="4">
                        <TextBox Text="{Binding EditableRemark}"
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 Watermark="输入备注..." />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="保存"
                                    Command="{Binding SaveRemarkCommand}"
                                    Padding="8,4" FontSize="12" />
                            <Button Content="取消"
                                    Command="{Binding CancelEditRemarkCommand}"
                                    Padding="8,4" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="原始 URL" FontSize="12" Foreground="Gray" />
                    <TextBlock Text="{Binding DisplayOriginalUrl}" FontSize="12"
                               TextDecorations="Underline" Foreground="#1A73E8" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="标准化 URL" FontSize="12" Foreground="Gray" />
                    <TextBlock Text="{Binding DisplayNormalizedUrl}" FontSize="12"
                               Foreground="Gray" />
                </StackPanel>

                <!-- Trash action -->
                <Button Content="移入回收站"
                        Command="{Binding TrashSelectedItemCommand}"
                        HorizontalAlignment="Left"
                        Padding="12,6" FontSize="13"
                        Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Panel>
</UserControl>
