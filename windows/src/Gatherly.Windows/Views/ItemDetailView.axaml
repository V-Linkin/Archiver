<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:conv="using:Gatherly.Windows.Views.Converters"
             xmlns:comp="using:Gatherly.Windows.Views.Components"
             x:Class="Gatherly.Windows.Views.ItemDetailView"
             x:DataType="vm:MainWindowViewModel">

    <DockPanel>
        <!-- Top bar with back button and actions -->
        <Border DockPanel.Dock="Top" Background="#FAFAFA"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="16,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <!-- Back button -->
                <Button Content="← 返回"
                        Command="{Binding NavigateBackCommand}"
                        Classes="ToolbarButton" />

                <!-- Divider -->
                <Border Width="1" Height="20"
                        Background="#E0E0E0"
                        VerticalAlignment="Center" />

                <!-- Action buttons -->
                <Button Content="编辑"
                        Click="EditItem_Click"
                        Classes="ToolbarButton" />
                <Button Content="移动"
                        Click="MoveItem_Click"
                        Classes="ToolbarButton" />
                <Button Content="导出"
                        Click="ExportItem_Click"
                        Classes="ToolbarButton" />
                <Button Content="删除"
                        Click="TrashConfirm_Click"
                        Classes="DangerButton" />
            </StackPanel>
        </Border>

        <!-- Content area -->
        <ScrollViewer x:Name="DetailScrollViewer">
            <StackPanel Spacing="20" Margin="24,16,24,24"
                        MaxWidth="800">

                <!-- Image gallery - horizontal scroll -->
                <StackPanel Spacing="8"
                            IsVisible="{Binding HasImages}">
                    <TextBlock Text="图片" FontSize="14" Foreground="Gray" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding ImageAssets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MediaAssetDisplay">
                                    <Button Padding="0" Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="0,0,8,0"
                                            Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenImageViewerCommand}"
                                            CommandParameter="{Binding}">
                                        <Border MaxWidth="300" MaxHeight="400" CornerRadius="6"
                                                ClipToBounds="True" Background="#F0F0F0">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="复制" Click="ImageCopy_Click"
                                                              Tag="{Binding FullPath}" />
                                                    <MenuItem Header="另存为..." Click="ImageSaveAs_Click"
                                                              Tag="{Binding FullPath}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Image Source="{Binding FullPath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                                   Stretch="Uniform" />
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Video preview card -->
                <StackPanel Spacing="8"
                            IsVisible="{Binding HasVideos}">
                    <TextBlock Text="视频" FontSize="14" Foreground="Gray" />
                    <!-- Preview card with cover + play button -->
                    <Border CornerRadius="10" ClipToBounds="True"
                            Background="#1A1A1A"
                            MaxWidth="480" MaxHeight="320"
                            HorizontalAlignment="Left"
                            Cursor="Hand"
                            PointerPressed="VideoCard_PointerPressed">
                        <Panel>
                            <Image Source="{Binding VideoCoverImagePath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                   Stretch="Uniform" Opacity="0.9" />
                            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Width="64" Height="64" CornerRadius="32"
                                    Background="#80000000" BorderBrush="#40FFFFFF" BorderThickness="2">
                                <TextBlock Text="▶" FontSize="28" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="3,0,0,0" />
                            </Border>
                        </Panel>
                    </Border>
                    <!-- Video file info + action buttons -->
                    <ItemsControl ItemsSource="{Binding VideoAssets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MediaAssetDisplay">
                                <StackPanel Spacing="4" Margin="0,4,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="🎬" FontSize="14" />
                                        <TextBlock Text="{Binding FileName}" FontSize="13" />
                                        <TextBlock Text="{Binding FileSizeDisplay}" FontSize="12" Foreground="Gray"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="打开视频" FontSize="12" Padding="10,4"
                                                Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenVideoFileCommand}"
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding FileExists}" />
                                        <Button Content="打开所在文件夹" FontSize="12" Padding="10,4"
                                                Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenVideoFolderCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Metadata — InfoRow (aligned to macOS metadataSection) -->
                <StackPanel Spacing="0">
                    <comp:InfoRow Label="平台" Value="{Binding DisplayPlatform}" />
                    <comp:InfoRow Label="作者" Value="{Binding DisplayAuthor}" />
                    <comp:InfoRow Label="发布时间" Value="{Binding DisplayPublishDate}"
                                  IsVisible="{Binding HasPublishDate}" />
                    <comp:InfoRow Label="导入时间" Value="{Binding DisplayImportDate}" />
                    <comp:InfoRow Label="文件夹" Value="{Binding DisplayFolderName}"
                                  IsVisible="{Binding HasFolder}" />
                </StackPanel>

                <!-- Original URL — clickable link -->
                <StackPanel Spacing="4"
                            IsVisible="{Binding DisplayOriginalUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Border Padding="0,6" BorderBrush="{StaticResource SeparatorColor}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="24,Auto,*">
                            <TextBlock Grid.Column="0" Text="🔗" FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="原始链接" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="2" Text="{Binding DisplayOriginalUrl}"
                                       FontSize="12" Foreground="{StaticResource TextLink}"
                                       TextDecorations="Underline" TextWrapping="Wrap"
                                       Cursor="Hand" VerticalAlignment="Center"
                                       PointerPressed="OriginalUrl_PointerPressed" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Body -->
                <StackPanel Spacing="4">
                    <TextBlock Text="正文" FontSize="12" Foreground="Gray" />
                    <Border Background="#F8F8F8" CornerRadius="8" Padding="16">
                        <SelectableTextBlock Text="{Binding DisplayBody}"
                                   TextWrapping="Wrap" FontSize="14" LineHeight="24" />
                    </Border>
                    <!-- Body links -->
                    <ItemsControl ItemsSource="{Binding DisplayBodyLinks}"
                                  IsVisible="{Binding HasDisplayBodyLinks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ContentLinkDisplay">
                                <TextBlock Text="{Binding Url}" FontSize="12"
                                           TextDecorations="Underline" Foreground="#1A73E8"
                                           Cursor="Hand" Margin="0,2"
                                           PointerPressed="BodyLink_PointerPressed"
                                           Tag="{Binding Url}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Remark -->
                <StackPanel Spacing="4">
                    <TextBlock Text="备注" FontSize="12" Foreground="Gray" />
                    <StackPanel IsVisible="{Binding !IsEditingRemark}">
                        <TextBlock Text="{Binding DisplayRemark, FallbackValue='暂无备注'}"
                                   FontSize="13" FontStyle="Italic"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel IsVisible="{Binding IsEditingRemark}" Spacing="8">
                        <TextBox Text="{Binding EditableRemark}"
                                 AcceptsReturn="True"
                                 MinHeight="80"
                                 Watermark="输入备注..." />
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
