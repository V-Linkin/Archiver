<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:conv="using:Gatherly.Windows.Views.Converters"
             xmlns:comp="using:Gatherly.Windows.Views.Components"
             x:Class="Gatherly.Windows.Views.ItemDetailView"
             x:DataType="vm:MainWindowViewModel">

    <DockPanel>
        <!-- Top bar with back button and actions -->
        <Border DockPanel.Dock="Top" Background="#FAFAFA"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="16,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <!-- Back button -->
                <Button Content="← 返回"
                        Command="{Binding NavigateBackCommand}"
                        Classes="ToolbarButton" />

                <!-- Divider -->
                <Border Width="1" Height="20"
                        Background="#E0E0E0"
                        VerticalAlignment="Center" />

                <!-- Action buttons -->
                <Button Content="编辑"
                        Click="EditItem_Click"
                        Classes="ToolbarButton" />
                <Button Content="移动"
                        Click="MoveItem_Click"
                        Classes="ToolbarButton" />
                <Button Content="导出"
                        Click="ExportItem_Click"
                        Classes="ToolbarButton" />
                <Button Content="删除"
                        Click="TrashConfirm_Click"
                        Classes="DangerButton" />
            </StackPanel>
        </Border>

        <!-- Content area -->
        <ScrollViewer x:Name="DetailScrollViewer">
            <StackPanel Spacing="0" Margin="24,16,24,24"
                        MaxWidth="800">

                <!-- ===== Media Section — unified horizontal gallery ===== -->
                <StackPanel Spacing="0">
                    <!-- Horizontal gallery: images first, then videos -->
                    <Border IsVisible="{Binding HasMedia}"
                            CornerRadius="12" ClipToBounds="True"
                            Background="#F0F0F0" MinHeight="280">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="8">
                                <!-- Image tiles -->
                                <ItemsControl ItemsSource="{Binding ImageAssets}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="12" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MediaAssetDisplay">
                                            <Button Padding="0" Background="Transparent"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenImageViewerCommand}"
                                                    CommandParameter="{Binding}">
                                                <Border Height="280" CornerRadius="8"
                                                        ClipToBounds="True" Background="#F0F0F0">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="复制" Click="ImageCopy_Click"
                                                                      Tag="{Binding FullPath}" />
                                                            <MenuItem Header="另存为..." Click="ImageSaveAs_Click"
                                                                      Tag="{Binding FullPath}" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Image Source="{Binding FullPath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Video tiles -->
                                <ItemsControl ItemsSource="{Binding VideoAssets}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="12" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MediaAssetDisplay">
                                            <Button Padding="0" Background="Transparent"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenMediaCommand}"
                                                    CommandParameter="{Binding}">
                                                <Border Height="280" Width="400" CornerRadius="8"
                                                        ClipToBounds="True" Background="#1A1A1A">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="另存为..." Click="ImageSaveAs_Click"
                                                                      Tag="{Binding FullPath}" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Panel>
                                                        <!-- Video thumbnail via Shell (or black fallback) -->
                                                        <Image Source="{Binding FullPath, Converter={x:Static conv:VideoThumbnailConverter.Instance}}"
                                                               Stretch="UniformToFill" />
                                                        <!-- Play icon overlay — macOS play.circle.fill 48pt -->
                                                        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                Width="48" Height="48" CornerRadius="24"
                                                                Background="#80000000">
                                                            <TextBlock Text="▶" FontSize="22" Foreground="White"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Margin="2,0,0,0" />
                                                        </Border>
                                                    </Panel>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Media empty state -->
                    <Border IsVisible="{Binding !HasMedia}"
                            Background="#F0F0F0" CornerRadius="12" MinHeight="200"
                            HorizontalAlignment="Stretch">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Spacing="8">
                            <TextBlock Text="无媒体内容" FontSize="12"
                                       Foreground="{StaticResource TextTertiary}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="{StaticResource SeparatorColor}" Margin="0,16" />

                <!-- Metadata InfoRow -->
                <StackPanel Spacing="0">
                    <comp:InfoRow Label="平台" Value="{Binding DisplayPlatform}" />
                    <comp:InfoRow Label="作者" Value="{Binding DisplayAuthor}" />
                    <comp:InfoRow Label="发布时间" Value="{Binding DisplayPublishDate}"
                                  IsVisible="{Binding HasPublishDate}" />
                    <comp:InfoRow Label="导入时间" Value="{Binding DisplayImportDate}" />
                    <comp:InfoRow Label="文件夹" Value="{Binding DisplayFolderName}"
                                  IsVisible="{Binding HasFolder}" />
                </StackPanel>

                <!-- Original URL -->
                <StackPanel Spacing="4"
                            IsVisible="{Binding DisplayOriginalUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Border Padding="0,6" BorderBrush="{StaticResource SeparatorColor}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="24,Auto,*">
                            <TextBlock Grid.Column="0" Text="🔗" FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="原始链接" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="2" Text="{Binding DisplayOriginalUrl}"
                                       FontSize="12" Foreground="{StaticResource TextLink}"
                                       TextDecorations="Underline" TextWrapping="Wrap"
                                       Cursor="Hand" VerticalAlignment="Center"
                                       PointerPressed="OriginalUrl_PointerPressed" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Remark -->
                <StackPanel Spacing="8">
                    <TextBlock Text="备注" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DisplayRemark, FallbackValue='暂无备注'}"
                               FontSize="14" Foreground="{StaticResource TextPrimary}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding !IsEditingRemark}" />
                    <TextBox Text="{Binding EditableRemark}"
                             AcceptsReturn="True"
                             MinHeight="80"
                             Watermark="输入备注..."
                             IsVisible="{Binding IsEditingRemark}" />
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="{StaticResource SeparatorColor}" Margin="0,4" />

                <!-- Body -->
                <StackPanel Spacing="8">
                    <TextBlock Text="正文" FontSize="16" FontWeight="SemiBold" />
                    <comp:MarkdownTextBlock x:Name="BodyMarkdownRenderer"
                                            IsVisible="{Binding HasDisplayBody}" />
                    <TextBlock Text="暂无正文内容"
                               FontSize="14"
                               Foreground="{StaticResource TextTertiary}"
                               IsVisible="{Binding !HasDisplayBody}" />
                    <!-- Body links -->
                    <ItemsControl ItemsSource="{Binding DisplayBodyLinks}"
                                  IsVisible="{Binding HasDisplayBodyLinks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ContentLinkDisplay">
                                <TextBlock Text="{Binding Url}" FontSize="12"
                                           TextDecorations="Underline" Foreground="{StaticResource TextLink}"
                                           Cursor="Hand" Margin="0,2"
                                           PointerPressed="BodyLink_PointerPressed"
                                           Tag="{Binding Url}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
