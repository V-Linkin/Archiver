<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:Gatherly.Windows.Views.Converters"
        x:Class="Gatherly.Windows.Views.ImageViewerWindow"
        Title="图片查看"
        Width="900" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1A">

    <Grid RowDefinitions="*,Auto">
        <!-- Image display -->
        <Grid Grid.Row="0" Margin="16">
            <Image x:Name="MainImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

            <!-- Error message -->
            <TextBlock x:Name="ErrorText"
                       IsVisible="False"
                       Text="图片文件不存在"
                       FontSize="16" Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <!-- Left arrow -->
            <Button x:Name="PrevButton"
                    Content="◀"
                    FontSize="24"
                    Width="48" Height="48"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    BorderThickness="0"
                    CornerRadius="24"
                    Click="Prev_Click"
                    IsVisible="False" />

            <!-- Right arrow -->
            <Button x:Name="NextButton"
                    Content="▶"
                    FontSize="24"
                    Width="48" Height="48"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    BorderThickness="0"
                    CornerRadius="24"
                    Click="Next_Click"
                    IsVisible="False" />
        </Grid>

        <!-- Bottom bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="16" Margin="0,0,0,16">
            <TextBlock x:Name="PageInfo"
                       Text="1 / 1"
                       FontSize="14" Foreground="#CCCCCC"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="FileNameText"
                       FontSize="12" Foreground="#888888"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
