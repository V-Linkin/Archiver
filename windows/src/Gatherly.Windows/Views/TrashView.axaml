<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:m="using:Gatherly.Windows.Models"
             x:DataType="vm:TrashViewModel"
             x:Class="Gatherly.Windows.Views.TrashView">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="回收站"
                   FontSize="18" FontWeight="Bold" Margin="16,16,16,8" />

        <TextBlock DockPanel.Dock="Top"
                   Text="正在加载..."
                   IsVisible="{Binding IsBusy}"
                   Margin="16,4" />

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="Red" Margin="16,4" />

        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    Spacing="8" Margin="16,8">
            <Button Content="恢复"
                    Command="{Binding RestoreSelectedItemCommand}"
                    Padding="12,6" FontSize="13" />
            <Button Content="永久删除"
                    Command="{Binding PermanentlyDeleteSelectedItemCommand}"
                    Padding="12,6" FontSize="13"
                    Foreground="Red" />
        </StackPanel>

        <ListBox ItemsSource="{Binding TrashedItems}"
                 SelectedItem="{Binding SelectedItem}"
                 Margin="8,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,6">
                        <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}"
                                   FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{Binding Platform}"
                                       Foreground="Gray" FontSize="12" />
                            <TextBlock Text="已删除"
                                       Foreground="Red" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
