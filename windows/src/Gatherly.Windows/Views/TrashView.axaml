<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:m="using:Gatherly.Windows.Models"
             x:DataType="vm:TrashViewModel"
             x:Class="Gatherly.Windows.Views.TrashView">

    <DockPanel>
        <!-- Header with clear all button -->
        <DockPanel DockPanel.Dock="Top" Margin="16,16,16,8">
            <TextBlock Text="回收站" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" />
            <Button Content="清空回收站" DockPanel.Dock="Right"
                    Classes="DangerButton" Click="ClearAll_Click"
                    IsVisible="{Binding HasItems}" />
        </DockPanel>

        <!-- Info banner -->
        <Border DockPanel.Dock="Top" Background="#18000000" CornerRadius="6"
                Margin="16,0,16,8" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⏰" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="回收站中的内容将在30天后自动清除"
                           FontSize="12" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <TextBlock DockPanel.Dock="Top"
                   Text="正在加载..."
                   IsVisible="{Binding IsBusy}"
                   Foreground="{StaticResource TextTertiary}" Margin="16,4" />

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="{StaticResource DangerRed}" Margin="16,4" />

        <!-- Empty state -->
        <StackPanel IsVisible="{Binding !HasItems}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,40" Spacing="12">
            <TextBlock Text="🗑️" FontSize="40" HorizontalAlignment="Center" />
            <TextBlock Text="回收站是空的" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" />
            <TextBlock Text="删除的内容将在这里保留 30 天" FontSize="12"
                       Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Item list with per-row buttons -->
        <ListBox ItemsSource="{Binding TrashedItems}"
                 SelectedItem="{Binding SelectedItem}"
                 Margin="8,0">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Item">
                    <Border Padding="12,6" Margin="0,1"
                            Background="{StaticResource BackgroundCard}"
                            CornerRadius="6"
                            BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="32,*,Auto,Auto,Auto">
                            <!-- Platform icon -->
                            <TextBlock Grid.Column="0" Text="📁"
                                       FontSize="16" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <!-- Title + metadata -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="2">
                                <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}"
                                           FontWeight="Medium" FontSize="13"
                                           TextDecorations="Strikethrough"
                                           Foreground="{StaticResource TextSecondary}" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding DisplayPlatform}"
                                               FontSize="10" Foreground="{StaticResource TextTertiary}" />
                                    <TextBlock FontSize="10" Foreground="{StaticResource TextTertiary}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="删除于 {0:MM/dd}">
                                                <Binding Path="DeletedAt" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            <!-- Remaining days with color coding -->
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontSize="11" Margin="6,0,0,0"
                                       Foreground="{Binding DeletedAt, Converter={x:Static vm:RemainingDaysBrushConverter.Instance}}"
                                       FontWeight="{Binding DeletedAt, Converter={x:Static vm:RemainingDaysWeightConverter.Instance}}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="剩余 {0} 天">
                                        <Binding Path="DeletedAt"
                                                 Converter="{x:Static vm:RemainingDaysConverter.Instance}" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <!-- Per-row restore button -->
                            <Button Grid.Column="3" Content="恢复"
                                    Tag="{Binding}" Click="RowRestore_Click"
                                    Classes="SecondaryButton" Padding="8,3" FontSize="11" Margin="4,0" />
                            <!-- Per-row delete button -->
                            <Button Grid.Column="4" Content="永久删除"
                                    Tag="{Binding}" Click="RowDelete_Click"
                                    Classes="DangerButton" Padding="8,3" FontSize="11" Margin="4,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
