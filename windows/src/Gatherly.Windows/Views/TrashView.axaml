<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:m="using:Gatherly.Windows.Models"
             x:DataType="vm:TrashViewModel"
             x:Class="Gatherly.Windows.Views.TrashView">

    <DockPanel>
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="回收站"
                   FontSize="18" FontWeight="Bold" Margin="16,16,16,8" />

        <!-- Info banner — macOS: "回收站中的内容将在30天后自动清除" -->
        <Border DockPanel.Dock="Top" Background="#18000000" CornerRadius="6"
                Margin="16,0,16,8" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⏰" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="回收站中的内容将在30天后自动清除"
                           FontSize="12" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <TextBlock DockPanel.Dock="Top"
                   Text="正在加载..."
                   IsVisible="{Binding IsBusy}"
                   Foreground="{StaticResource TextTertiary}" Margin="16,4" />

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="{StaticResource DangerRed}" Margin="16,4" />

        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    Spacing="8" Margin="16,8">
            <Button Content="恢复"
                    Command="{Binding RestoreSelectedItemCommand}"
                    IsEnabled="{Binding HasSelectedTrashItem}"
                    Classes="SecondaryButton" />
            <Button Content="永久删除"
                    Command="{Binding PermanentlyDeleteSelectedItemCommand}"
                    IsEnabled="{Binding HasSelectedTrashItem}"
                    Classes="DangerButton" />
        </StackPanel>

        <!-- Empty state -->
        <StackPanel IsVisible="{Binding !HasItems}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,40" Spacing="8">
            <TextBlock Text="🗑️" FontSize="32" HorizontalAlignment="Center" />
            <TextBlock Text="回收站是空的" FontSize="14"
                       Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Item list -->
        <ListBox ItemsSource="{Binding TrashedItems}"
                 SelectedItem="{Binding SelectedItem}"
                 Margin="8,0">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Item">
                    <Border Padding="12,8" Margin="0,2"
                            Background="{StaticResource BackgroundCard}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
                        <Grid ColumnDefinitions="32,*,Auto">
                            <!-- Platform icon -->
                            <TextBlock Grid.Column="0" Text="📁"
                                       FontSize="16" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <!-- Title + metadata -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="2">
                                <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}"
                                           FontWeight="Medium" FontSize="13"
                                           TextDecorations="Strikethrough"
                                           Foreground="{StaticResource TextSecondary}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DisplayPlatform}"
                                               FontSize="11" Foreground="{StaticResource TextTertiary}" />
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextTertiary}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="删除于 {0:MM/dd HH:mm}">
                                                <Binding Path="DeletedAt" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            <!-- Remaining days -->
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontSize="11" Margin="8,0,0,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="剩余 {0} 天">
                                        <Binding Path="DeletedAt"
                                                 Converter="{x:Static vm:RemainingDaysConverter.Instance}" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
