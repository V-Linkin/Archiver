<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:m="using:Gatherly.Windows.Models"
             xmlns:conv="using:Gatherly.Windows.Views.Converters"
             x:DataType="vm:HomeViewModel"
             x:Class="Gatherly.Windows.Views.HomeView">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="首页 — 最近内容"
                   FontSize="18" FontWeight="Bold" Margin="16,16,16,8" />

        <TextBlock DockPanel.Dock="Top"
                   Text="正在加载..."
                   IsVisible="{Binding IsBusy}"
                   Margin="16,4" />

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="Red" Margin="16,4" />


        <ListBox ItemsSource="{Binding RecentItems}"
                 SelectedItem="{Binding SelectedItem}"
                 Margin="8,0">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Item">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="4,6">
                        <!-- 首图缩略图 -->
                        <Border Width="56" Height="56" CornerRadius="4"
                                ClipToBounds="True" Background="#F0F0F0">
                            <Image Source="{Binding FirstImagePath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                   Stretch="UniformToFill" />
                        </Border>
                        <!-- 文字信息 -->
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}"
                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                       MaxWidth="300" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{Binding Platform}"
                                           Foreground="Gray" FontSize="12" />
                                <TextBlock Text="{Binding Author, FallbackValue='未知作者'}"
                                           Foreground="Gray" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
