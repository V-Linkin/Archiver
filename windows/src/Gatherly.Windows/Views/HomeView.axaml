<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:m="using:Gatherly.Windows.Models"
             xmlns:conv="using:Gatherly.Windows.Views.Converters"
             x:DataType="vm:HomeViewModel"
             x:Class="Gatherly.Windows.Views.HomeView">

    <DockPanel>
        <!-- 首页标题 -->
        <TextBlock DockPanel.Dock="Top" Text="拾屿 · 跨平台的私人内容岛"
                   FontSize="20" FontWeight="Bold" Margin="20,16,20,4" />

        <!-- 最近导入标题 -->
        <TextBlock DockPanel.Dock="Top" Text="最近导入"
                   FontSize="16" FontWeight="SemiBold" Margin="20,12,20,4" />

        <!-- 状态信息 -->
        <TextBlock DockPanel.Dock="Top" Text="正在加载..."
                   IsVisible="{Binding IsBusy}"
                   Foreground="Gray" Margin="20,2,20,2" />

        <TextBlock DockPanel.Dock="Top" Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="Red" Margin="20,2,20,2" />

        <!-- 空状态 -->
        <TextBlock DockPanel.Dock="Top" Text="最近 7 日暂无内容导入"
                   IsVisible="{Binding !HasItems}"
                   Foreground="Gray" FontSize="14" Margin="20,8,20,8" />

        <!-- 卡片列表 + 平台入口 -->
        <ScrollViewer>
            <StackPanel Margin="20,0,20,20" Spacing="20">
                <!-- 卡片列表 -->
                <ListBox ItemsSource="{Binding RecentItems}"
                         SelectedItem="{Binding SelectedItem}"
                         IsVisible="{Binding HasItems}"
                         Background="Transparent" BorderThickness="0"
                         Padding="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:Item">
                            <Border Width="200" Margin="0,0,12,12" CornerRadius="8"
                                    ClipToBounds="True" Background="#F8F8F8"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <!-- 封面图 -->
                                    <Border Height="140" Background="#F0F0F0">
                                        <Image Source="{Binding FirstImagePath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <!-- 文字区 -->
                                    <StackPanel Margin="8,6,8,8" Spacing="3">
                                        <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding DisplayPlatform}"
                                                       FontSize="11" Foreground="#666" />
                                            <TextBlock Text="{Binding Author, FallbackValue='未知作者'}"
                                                       FontSize="11" Foreground="#999"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 平台入口 -->
                <StackPanel Spacing="10"
                            IsVisible="{Binding HasPlatforms}">
                    <TextBlock Text="平台入口" FontSize="16" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding PlatformEntries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlatformEntryDisplay">
                                <Button Padding="0" Background="Transparent"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="PlatformEntry_Click">
                                    <Border CornerRadius="8" Margin="0,0,10,10"
                                            Padding="12,10" Background="#F8F8F8"
                                            BorderBrush="#E0E0E0" BorderThickness="1"
                                            MinWidth="150">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Border Width="32" Height="32" CornerRadius="6"
                                                    Background="#E8E8E8" ClipToBounds="True">
                                                <Image Source="{Binding LogoPath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding CountDisplay}"
                                                           FontSize="11" Foreground="Gray" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
