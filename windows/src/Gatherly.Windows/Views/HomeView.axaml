<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gatherly.Windows.ViewModels"
             xmlns:m="using:Gatherly.Windows.Models"
             xmlns:conv="using:Gatherly.Windows.Views.Converters"
             x:DataType="vm:HomeViewModel"
             x:Class="Gatherly.Windows.Views.HomeView">

    <DockPanel>
        <!-- Header: title + search box -->
        <Border DockPanel.Dock="Top" Padding="20,16,20,8">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="拾屿 · 跨平台的私人内容岛"
                           FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="SearchBox"
                         Text="{Binding SearchQuery}"
                         Watermark="搜索内容..."
                         Width="280"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ====== Normal home content (visible when not searching) ====== -->
        <StackPanel IsVisible="{Binding ShowHomeContent}">
            <StackPanel DockPanel.Dock="Top" Margin="20,12,20,4" Spacing="8">
                <TextBlock Text="一键归档" FontSize="16" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{Binding ImportUrl}" Watermark="粘贴链接..." Width="400" />
                    <Button Content="导入" Command="{Binding ImportLinkCommand}" Padding="16,6" />
                </StackPanel>
                <TextBlock Text="{Binding ImportStatusMessage}"
                           IsVisible="{Binding ImportStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           FontSize="12" Foreground="#E8A020" />
            </StackPanel>

            <TextBlock Text="最近导入" FontSize="16" FontWeight="SemiBold" Margin="20,12,20,4" />

            <TextBlock Text="正在加载..." IsVisible="{Binding IsBusy}" Foreground="Gray" Margin="20,2,20,2" />
            <TextBlock Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="Red" Margin="20,2,20,2" />
            <TextBlock Text="最近 7 日暂无内容导入" IsVisible="{Binding !HasItems}"
                       Foreground="Gray" FontSize="14" Margin="20,8,20,8" />

            <ScrollViewer>
                <StackPanel Margin="20,0,20,20" Spacing="20">
                    <ListBox ItemsSource="{Binding RecentItems}" IsVisible="{Binding HasItems}"
                             Background="Transparent" BorderThickness="0" Padding="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:Item">
                                <Border Width="200" Padding="8" CornerRadius="12" ClipToBounds="True"
                                        Background="{StaticResource BackgroundCard}"
                                        BorderBrush="{StaticResource BorderLight}" BorderThickness="1"
                                        PointerPressed="RecentItemCard_PointerPressed">
                                    <Border.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="不显示该内容" Click="HideRecentItem_Click" Tag="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="删除" Click="DeleteRecentItem_Click" Tag="{Binding}" Foreground="{StaticResource DangerRed}" />
                                        </MenuFlyout>
                                    </Border.ContextFlyout>
                                    <StackPanel>
                                        <Border Height="160" Background="{StaticResource BackgroundTertiary}" CornerRadius="8" ClipToBounds="True">
                                            <Image Source="{Binding FirstImagePath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Spacing="4" Margin="0,6,0,0">
                                            <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}" FontWeight="Medium" FontSize="13" TextTrimming="CharacterEllipsis" MaxLines="2" />
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding DisplayPlatform}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                                <TextBlock Text="{Binding Author, FallbackValue='未知作者'}" FontSize="11" Foreground="{StaticResource TextTertiary}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Spacing="10" IsVisible="{Binding HasPlatforms}">
                        <TextBlock Text="平台入口" FontSize="16" FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{Binding PlatformEntries}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PlatformEntryDisplay">
                                    <Button Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="PlatformEntry_Click">
                                        <Border CornerRadius="10" Margin="0,0,10,10" Padding="12"
                                                Background="{StaticResource BackgroundCard}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" MinWidth="150">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border Width="36" Height="36" CornerRadius="8" Background="{StaticResource BackgroundTertiary}" ClipToBounds="True">
                                                    <Image Source="{Binding LogoPath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}" Stretch="UniformToFill" />
                                                </Border>
                                                <StackPanel VerticalAlignment="Center" Spacing="1">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" />
                                                    <TextBlock Text="{Binding CountDisplay}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <!-- ====== Search results (visible when searching) ====== -->
        <DockPanel IsVisible="{Binding ShowSearchResults}">
            <!-- Result count -->
            <Border DockPanel.Dock="Top" Margin="20,4,20,4"
                    IsVisible="{Binding HasSearchResults}">
                <TextBlock Foreground="{StaticResource TextTertiary}" FontSize="12">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="共 {0} 条结果">
                            <Binding Path="SearchResultCount" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Border>

            <!-- Content area: Grid fills remaining DockPanel space -->
            <Grid>
                <!-- No results (centered) -->
                <StackPanel IsVisible="{Binding !HasSearchResults}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="🔍" FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="没有找到相关内容" FontSize="14"
                               Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center" />
                    <TextBlock Text="尝试修改搜索关键词" FontSize="12"
                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Result cards (grid layout) -->
                <ScrollViewer IsVisible="{Binding HasSearchResults}">
                    <ItemsControl ItemsSource="{Binding SearchResults}" Margin="20,0,20,20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:Item">
                                <Border Width="200" Padding="8" Margin="0,0,12,12"
                                        CornerRadius="12" ClipToBounds="True"
                                        Background="{StaticResource BackgroundCard}"
                                        BorderBrush="{StaticResource BorderLight}" BorderThickness="1"
                                        PointerPressed="SearchResultCard_PointerPressed">
                                    <Border.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="移动到平台" Click="SearchResultMoveToPlatform_Click" Tag="{Binding}" />
                                            <MenuItem Header="移动到文件夹" Click="SearchResultMoveToFolder_Click" Tag="{Binding}" />
                                            <MenuItem Header="删除" Click="SearchResultDelete_Click" Tag="{Binding}" Foreground="{StaticResource DangerRed}" />
                                        </MenuFlyout>
                                    </Border.ContextFlyout>
                                    <StackPanel>
                                        <Border Height="160" Background="{StaticResource BackgroundTertiary}" CornerRadius="8" ClipToBounds="True">
                                            <Image Source="{Binding FirstImagePath, Converter={x:Static conv:FilePathToBitmapConverter.Instance}}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Spacing="4" Margin="0,6,0,0">
                                            <TextBlock Text="{Binding Title, FallbackValue='未命名内容'}" FontWeight="Medium" FontSize="13" TextTrimming="CharacterEllipsis" MaxLines="2" />
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding DisplayPlatform}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                                <TextBlock Text="{Binding Author, FallbackValue='未知作者'}" FontSize="11" Foreground="{StaticResource TextTertiary}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </DockPanel>
</UserControl>
