<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Gatherly.Windows.ViewModels"
        xmlns:views="using:Gatherly.Windows.Views"
        x:Class="Gatherly.Windows.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Gatherly Windows"
        Width="1024" Height="768"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="200,*,300">

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#2C2C2C" ClipToBounds="True">
            <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12" Spacing="4">
                <Border Background="#3A3A3A" Height="1" CornerRadius="2" Margin="4,4" />
                <Button Content="📦 导入备份"
                        Click="ImportBackup_Click"
                        IsEnabled="{Binding !IsImportingBackup}"
                        HorizontalContentAlignment="Left"
                        Padding="16,10" Background="Transparent"
                        Foreground="White" BorderThickness="0" />
                <Border IsVisible="{Binding IsImportingBackup}"
                        Background="#3A3A3A" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="正在导入..." Foreground="#AAAAAA" FontSize="12" />
                </Border>
                <Border IsVisible="{Binding HasBackupImportStatus}"
                        Background="#2D4A2D" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="{Binding BackupImportStatus}" Foreground="#8FD88F" FontSize="12" />
                </Border>
                <Border IsVisible="{Binding HasBackupImportError}"
                        Background="#4A2D2D" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="{Binding BackupImportError}" Foreground="#D88F8F" FontSize="12"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <StackPanel Margin="0,16,0,0" Spacing="2">
                <TextBlock Text="拾屿"
                           Foreground="White" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,16" />

                <Button Content="🏠 首页"
                        Command="{Binding ShowHomeCommand}"
                        HorizontalContentAlignment="Left"
                        Padding="16,10" Background="Transparent"
                        Foreground="White" BorderThickness="0" />

                <Button Content="🔍 搜索"
                        Command="{Binding ShowSearchCommand}"
                        HorizontalContentAlignment="Left"
                        Padding="16,10" Background="Transparent"
                        Foreground="White" BorderThickness="0" />

                <Button Content="🗑️ 回收站"
                        Command="{Binding ShowTrashCommand}"
                        HorizontalContentAlignment="Left"
                        Padding="16,10" Background="Transparent"
                        Foreground="White" BorderThickness="0" />
            </StackPanel>
            </DockPanel>
        </Border>

        <!-- Center Content -->
        <Panel Grid.Column="1">
            <views:HomeView DataContext="{Binding Home}" />
        </Panel>

        <!-- Right Detail -->
        <views:ItemDetailView Grid.Column="2" DataContext="{Binding .}" />

    </Grid>
</Window>
