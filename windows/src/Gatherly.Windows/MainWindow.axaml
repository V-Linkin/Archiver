<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Gatherly.Windows.ViewModels"
        xmlns:views="using:Gatherly.Windows.Views"
        x:Class="Gatherly.Windows.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="拾屿 Gatherly"
        Width="1024" Height="768"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="220,*">

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#F5F5F5" ClipToBounds="True"
                BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <DockPanel>
            <!-- Bottom: Settings + trash (macOS style) -->
            <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12" Spacing="4">
                <Border Background="#E0E0E0" Height="1" CornerRadius="1" Margin="8,4" />
                <Button Content="🗑️ 回收站"
                        Command="{Binding ShowTrashCommand}"
                        HorizontalContentAlignment="Left"
                        Padding="16,8" Background="Transparent"
                        Foreground="#555" BorderThickness="0" FontSize="13" />
                <Button Content="⚙️ 设置"
                        Command="{Binding ShowSettingsCommand}"
                        HorizontalContentAlignment="Left"
                        Padding="16,8" Background="Transparent"
                        Foreground="#555" BorderThickness="0" FontSize="13" />
                <!-- Import backup (weakened, not visible in macOS) -->
                <Border Background="#E0E0E0" Height="1" CornerRadius="1" Margin="8,4" />
                <Button Content="📦 导入备份"
                        Click="ImportBackup_Click"
                        IsEnabled="{Binding !IsImportingBackup}"
                        HorizontalContentAlignment="Left"
                        Padding="16,4" Background="Transparent"
                        Foreground="#CCC" BorderThickness="0" FontSize="11" />
                <Border IsVisible="{Binding IsImportingBackup}"
                        Background="#FFF8E1" CornerRadius="6" Padding="10,6">
                    <TextBlock Text="正在导入..." Foreground="#888" FontSize="11" />
                </Border>
                <Border IsVisible="{Binding HasBackupImportStatus}"
                        Background="#E8F5E9" CornerRadius="6" Padding="10,6">
                    <TextBlock Text="{Binding BackupImportStatus}" Foreground="#2E7D32" FontSize="11" />
                </Border>
                <Border IsVisible="{Binding HasBackupImportError}"
                        Background="#FFEBEE" CornerRadius="6" Padding="10,6">
                    <TextBlock Text="{Binding BackupImportError}" Foreground="#C62828" FontSize="11"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <!-- Middle: Scrollable nav -->
            <ScrollViewer>
                <StackPanel Margin="0,20,0,8" Spacing="2">
                    <!-- Home — light gray selected state like macOS -->
                    <Border x:Name="HomeNavBorder" Background="#E4E4E4" CornerRadius="8"
                            Margin="8,0" Padding="0,1">
                        <Button Content="🏠 首页"
                                Command="{Binding ShowHomeCommand}"
                                HorizontalContentAlignment="Left"
                                Padding="12,8" Background="Transparent"
                                Foreground="#111" BorderThickness="0" FontSize="13" />
                    </Border>

                    <!-- Platform section -->
                    <TextBlock Text="平台" Foreground="#999" FontSize="11"
                               Margin="20,12,16,4" />

                    <ItemsControl ItemsSource="{Binding SidebarPlatforms}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlatformEntryDisplay">
                                <Button HorizontalContentAlignment="Left"
                                        Padding="20,7" Background="Transparent"
                                        Foreground="#444" BorderThickness="0" FontSize="13"
                                        Click="PlatformEntry_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="★" FontSize="18" VerticalAlignment="Center"
                                                   Foreground="#C026D3" FontWeight="Bold" />
                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Unclassified content -->
                    <Button Content="📂 未分类内容"
                            HorizontalContentAlignment="Left"
                            Padding="20,7" Background="Transparent"
                            Foreground="#555" BorderThickness="0" FontSize="13" />

                    <!-- Add platform -->
                    <Button Content="＋ 新增平台"
                            Command="{Binding OpenPlatformManagementCommand}"
                            HorizontalContentAlignment="Left"
                            Padding="20,7" Background="Transparent"
                            Foreground="#999" BorderThickness="0" FontSize="12" />
                </StackPanel>
            </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Panel Grid.Column="1" Background="White">
            <views:HomeView x:Name="HomeViewControl" DataContext="{Binding Home}" />
            <views:SearchView x:Name="SearchViewControl" DataContext="{Binding Search}" IsVisible="False" />
            <views:TrashView x:Name="TrashViewControl" DataContext="{Binding Trash}" IsVisible="False" />
            <views:ContentListView x:Name="ContentListViewControl" DataContext="{Binding ContentList}" IsVisible="False" />
            <views:ItemDetailView x:Name="DetailViewControl" DataContext="{Binding .}" IsVisible="False" />
            <views:SettingsView x:Name="SettingsViewControl" DataContext="{Binding Settings}" IsVisible="False" />
        </Panel>

    </Grid>
</Window>
