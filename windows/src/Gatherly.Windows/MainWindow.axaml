<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Gatherly.Windows.ViewModels"
        xmlns:views="using:Gatherly.Windows.Views"
        x:Class="Gatherly.Windows.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="拾屿 Gatherly"
        Width="1024" Height="768"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="200,*">

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#2C2C2C" ClipToBounds="True">
            <DockPanel>
            <!-- Bottom: Import backup -->
            <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12" Spacing="4">
                <Border Background="#3A3A3A" Height="1" CornerRadius="2" Margin="4,4" />
                <Button Content="📦 导入备份"
                        Click="ImportBackup_Click"
                        IsEnabled="{Binding !IsImportingBackup}"
                        HorizontalContentAlignment="Left"
                        Padding="16,10" Background="Transparent"
                        Foreground="White" BorderThickness="0" />
                <Border IsVisible="{Binding IsImportingBackup}"
                        Background="#3A3A3A" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="正在导入..." Foreground="#AAAAAA" FontSize="12" />
                </Border>
                <Border IsVisible="{Binding HasBackupImportStatus}"
                        Background="#2D4A2D" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="{Binding BackupImportStatus}" Foreground="#8FD88F" FontSize="12" />
                </Border>
                <Border IsVisible="{Binding HasBackupImportError}"
                        Background="#4A2D2D" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="{Binding BackupImportError}" Foreground="#D88F8F" FontSize="12"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <!-- Middle: Scrollable nav -->
            <ScrollViewer>
                <StackPanel Margin="0,16,0,0" Spacing="2">
                    <TextBlock Text="拾屿"
                               Foreground="White" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,16" />

                    <!-- Fixed entries -->
                    <Button Content="🏠 首页"
                            Command="{Binding ShowHomeCommand}"
                            HorizontalContentAlignment="Left"
                            Padding="16,10" Background="Transparent"
                            Foreground="White" BorderThickness="0" />

                    <Button Content="🔍 搜索"
                            Command="{Binding ShowSearchCommand}"
                            HorizontalContentAlignment="Left"
                            Padding="16,10" Background="Transparent"
                            Foreground="White" BorderThickness="0" />

                    <!-- Platform entries -->
                    <Border Background="#3A3A3A" Height="1" CornerRadius="2" Margin="12,8" />
                    <TextBlock Text="平台" Foreground="#888" FontSize="11"
                               Margin="16,4,16,4" />

                    <ItemsControl ItemsSource="{Binding SidebarPlatforms}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlatformEntryDisplay">
                                <Button HorizontalContentAlignment="Left"
                                        Padding="16,8" Background="Transparent"
                                        Foreground="White" BorderThickness="0"
                                        Click="PlatformEntry_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Count}" FontSize="11"
                                                   Foreground="#888" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Trash -->
                    <Border Background="#3A3A3A" Height="1" CornerRadius="2" Margin="12,8" />
                    <Button Content="🗑️ 回收站"
                            Command="{Binding ShowTrashCommand}"
                            HorizontalContentAlignment="Left"
                            Padding="16,10" Background="Transparent"
                            Foreground="White" BorderThickness="0" />
                </StackPanel>
            </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Panel Grid.Column="1">
            <views:HomeView x:Name="HomeViewControl" DataContext="{Binding Home}" />
            <views:SearchView x:Name="SearchViewControl" DataContext="{Binding Search}" IsVisible="False" />
            <views:TrashView x:Name="TrashViewControl" DataContext="{Binding Trash}" IsVisible="False" />
            <views:ContentListView x:Name="ContentListViewControl" DataContext="{Binding ContentList}" IsVisible="False" />
            <views:ItemDetailView x:Name="DetailViewControl" DataContext="{Binding .}" IsVisible="False" />
        </Panel>

    </Grid>
</Window>
